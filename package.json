{
  "name": "obsidian-outline-sync",
  "version": "2.0.0",
  "description": "Bidirectional sync between Obsidian and Outline (self-hosted or cloud). Folder-note hierarchy, conflict-safe, mobile-compatible.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "jest",
    "generate:api": "orval",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "outline",
    "sync",
    "knowledge-base"
  ],
  "author": "GTez",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^16.11.6",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.17.3",
    "jest": "^30.3.0",
    "obsidian": "latest",
    "orval": "^7.13.2",
    "prettier": "^3.4.2",
    "ts-jest": "^29.4.6",
    "tslib": "^2.4.0",
    "typescript": "^5.0.0"
  }
}
